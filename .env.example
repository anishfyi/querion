# Copy to .env and fill in. Never commit .env.
# These names are referenced as ${VAR} in querion.yaml.

# Postgres: use a READ-ONLY role. Querion enforces read-only too, but the
# database role is your strongest guarantee.
QUERION_DATABASE_DSN=postgresql://readonly_user:password@localhost:5432/yourdb

# Example HTTP source secrets (rename per your platform)
EXAMPLE_API_KEY=sk_live_xxx

# Optional: pin the Claude Code CLI binary if it is not on PATH
# QUERION_CLAUDE_BIN=/usr/local/bin/claude
